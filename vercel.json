{
  "version": 2,
  "name": "cdn-optimizer",
  "functions": {
    "api/*": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/v1/(.*)", "destination": "/api/index" },
    { "source": "/optimize/(.*)", "destination": "/api/index" },
    { "source": "/cdn/(.*)", "destination": "/api/index" }
  ]
}
